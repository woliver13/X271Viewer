<Window x:Class="X271Viewer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:X271Viewer.Wpf"
        mc:Ignorable="d"
        Title="X271 Viewer" Height="600" Width="1000">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open…"       Click="Open_Click"   InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Export JSON…" Command="{x:Static local:MainWindow.ExportCommand}"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="120"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Left pane: HL loop tree -->
            <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="0,0,1,0">
                <TreeView x:Name="TreePane" Background="#FAFAFA"
                          SelectedItemChanged="TreePane_SelectedItemChanged"/>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- Right panes stacked vertically -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top-right: interpretation pane (placeholder for Phase 3) -->
                <Border Grid.Row="0" BorderBrush="#CCC" BorderThickness="0,0,0,1">
                    <ScrollViewer>
                        <TextBlock x:Name="InterpretationPane"
                                   Text="(Interpretation will appear here in Phase 3)"
                                   Margin="8" Foreground="#888" FontStyle="Italic"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#DDD"/>

                <!-- Bottom-right: raw segment view -->
                <ScrollViewer Grid.Row="2">
                    <TextBox x:Name="RawSegmentPane"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="13"
                             Margin="8"
                             Text="Open a .edi, .txt, or .x12 file to begin."
                             TextWrapping="Wrap"
                             Background="Transparent"
                             BorderThickness="0"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
